# CoralStack — community-wide config.
# Copy to .env and edit. Per-service secrets live in services/<name>/.env.

# ─── Community identity ──────────────────────────────────────────────────────
# Short slug for this deployment. Used in docs, not in routing (yet).
COMMUNITY=campbellriver

# Root domain for all services. Subdomains derived: id.${BASE_DOMAIN},
# vault.${BASE_DOMAIN}, media.${BASE_DOMAIN}, photos.${BASE_DOMAIN} (web app),
# photos-api.${BASE_DOMAIN}, photos-accounts.${BASE_DOMAIN},
# photos-albums.${BASE_DOMAIN}, photos-storage.${BASE_DOMAIN} (MinIO S3 edge).
# This must be a domain whose DNS is hosted at Cloudflare (see README).
BASE_DOMAIN=campbellriver.coralstack.org

# ─── Host ────────────────────────────────────────────────────────────────────
TZ=America/Vancouver

# Root of the storage disk. Ente's MinIO blob store writes to
# ${STORAGE_PATH}/ente-minio. Jellyfin reads music from ${STORAGE_PATH}/music
# (managed by beets on the host).
STORAGE_PATH=/mnt/storage

# Where container data volumes go. Relative paths are resolved to absolute
# by setup.sh on first run and written back to .env — docker compose's
# `include:` semantics resolve relative paths inconsistently across root vs
# included compose files, so absolute is the only reliable path format.
# Leave as `./data` for the default (repo-root-relative), or set to an
# absolute path if you want data on a different disk.
DATA_PATH=./data

# ─── Admin box (Mac mini) ────────────────────────────────────────────────────
# OPNsense-assigned IP for the Mac mini on VLAN 10 (OPT1, 10.0.1.0/24).
# Set after completing Phase 4c of docs/PROXMOX_MIGRATION.md.
# Used by Open WebUI to reach Ollama on the Mac mini.
MAC_MINI_IP=10.0.1.10

# ─── TLS (Let's Encrypt via Cloudflare DNS-01) ───────────────────────────────
# Email Let's Encrypt uses for expiry notifications. Required.
ACME_EMAIL=you@example.com

# Cloudflare API token scoped to Zone:DNS:Edit for your domain. Create at
# https://dash.cloudflare.com/profile/api-tokens — see docs/QUICKSTART.md.
CF_API_TOKEN=
