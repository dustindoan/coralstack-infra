# CoralStack — community-wide config.
# Copy to .env and edit. Per-service secrets live in services/<name>/.env.

# ─── Community identity ──────────────────────────────────────────────────────
# Short slug for this deployment. Used in docs, not in routing (yet).
COMMUNITY=campbellriver

# Root domain for all services. Subdomains are derived: id.${BASE_DOMAIN},
# photos.${BASE_DOMAIN}, vault.${BASE_DOMAIN}, media.${BASE_DOMAIN}.
# This must be a domain whose DNS is hosted at Cloudflare (see README).
BASE_DOMAIN=campbellriver.coralstack.org

# ─── Host ────────────────────────────────────────────────────────────────────
TZ=America/Vancouver

# Root of the storage disk. Immich photos live under ${STORAGE_PATH}/photos,
# Jellyfin reads music from ${STORAGE_PATH}/music (managed by beets on the host).
STORAGE_PATH=/mnt/storage

# Where container data volumes go. Default is relative to the repo; change to
# an absolute path on your storage disk if you want data off the system SSD.
DATA_PATH=./data

# ─── TLS (Let's Encrypt via Cloudflare DNS-01) ───────────────────────────────
# Email Let's Encrypt uses for expiry notifications. Required.
ACME_EMAIL=you@example.com

# Cloudflare API token scoped to Zone:DNS:Edit for your domain. Create at
# https://dash.cloudflare.com/profile/api-tokens — see docs/QUICKSTART.md.
CF_API_TOKEN=
