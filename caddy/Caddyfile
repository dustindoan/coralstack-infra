{
	email {$ACME_EMAIL}

	# All sites get real Let's Encrypt certs via Cloudflare DNS-01.
	# No public exposure needed — Cloudflare creates _acme-challenge TXT
	# records and LE validates via DNS, not by hitting this box.
	acme_dns cloudflare {env.CF_API_TOKEN}
}

# ─── Landing page ────────────────────────────────────────────────────────────
{$BASE_DOMAIN} {
	respond "CoralStack — you're connected. Services: id, vault, photos, media." 200
}

# ─── Pocket ID (identity) ────────────────────────────────────────────────────
id.{$BASE_DOMAIN} {
	reverse_proxy pocket-id:1411
}

# ─── Vaultwarden ─────────────────────────────────────────────────────────────
vault.{$BASE_DOMAIN} {
	reverse_proxy /notifications/hub vaultwarden:3012
	reverse_proxy vaultwarden:80
}

# ─── Immich ──────────────────────────────────────────────────────────────────
photos.{$BASE_DOMAIN} {
	client_max_body_size 50000M  # large photo/video uploads
	reverse_proxy immich-server:2283
}

# ─── Jellyfin ────────────────────────────────────────────────────────────────
media.{$BASE_DOMAIN} {
	reverse_proxy jellyfin:8096
}
