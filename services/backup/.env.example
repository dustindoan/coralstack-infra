# CoralStack backups — restic + rclone.
#
# The destination is a config knob, NOT a vendor commitment. restic's repo
# format is open, encrypted, and deduplicated; rclone lets it target almost any
# provider — or a box you own — purely from the env vars below. Switching
# providers never means re-architecting. See docs/BACKUPS.md.

# ─── Repository: the destination ─────────────────────────────────────────────
# Choose ONE shape.
#
#  A) Local path (DEFAULT). Mounted into the container at /repo from
#     ${BACKUP_REPO_PATH} (root .env). Proves the mechanism and gives you a
#     restore-testable repo out of the box — but on the SAME host as the data,
#     so it is NOT real durability on its own. Point BACKUP_REPO_PATH at a
#     separate drive, or use shape (B), for an actual offsite copy.
RESTIC_REPOSITORY=/repo
#
#  B) Offsite, cloud-agnostic via rclone. Comment out the line above and set:
#       RESTIC_REPOSITORY=rclone:offsite:coralstack-<community>
#     where `offsite` is an rclone remote configured by the RCLONE_CONFIG_*
#     vars below. (restic shells out to rclone; rclone reads its whole config
#     from these env vars, so no rclone.conf file and no secret in the repo.)

# Restic repository password.
# *** TIER-1 SECRET. *** Without it the repository is mathematically
# unrecoverable — losing it means losing every backup. setup.sh generates one
# if this is left blank; copy it to paper in the safe (see secret tiering).
RESTIC_PASSWORD=

# ─── rclone remote (shape B only) ────────────────────────────────────────────
# Pattern: RCLONE_CONFIG_<REMOTE>_<KEY>=value  (REMOTE upper-cased; here OFFSITE)
#
# Backblaze B2:
#   RCLONE_CONFIG_OFFSITE_TYPE=b2
#   RCLONE_CONFIG_OFFSITE_ACCOUNT=<keyID>
#   RCLONE_CONFIG_OFFSITE_KEY=<applicationKey>
#
# Wasabi / Cloudflare R2 / any S3-compatible:
#   RCLONE_CONFIG_OFFSITE_TYPE=s3
#   RCLONE_CONFIG_OFFSITE_PROVIDER=Wasabi        # or Cloudflare, Minio, Other…
#   RCLONE_CONFIG_OFFSITE_ACCESS_KEY_ID=<key>
#   RCLONE_CONFIG_OFFSITE_SECRET_ACCESS_KEY=<secret>
#   RCLONE_CONFIG_OFFSITE_ENDPOINT=<s3-endpoint-host>
#
# SFTP (rsync.net, a friend's box, a co-op member's storage):
#   RCLONE_CONFIG_OFFSITE_TYPE=sftp
#   RCLONE_CONFIG_OFFSITE_HOST=<host>
#   RCLONE_CONFIG_OFFSITE_USER=<user>
#   RCLONE_CONFIG_OFFSITE_KEY_FILE=/keys/id_ed25519   # also bind-mount it in compose

# ─── Schedule + retention ────────────────────────────────────────────────────
# Cron expression for the nightly run (uses the container TZ from root .env).
BACKUP_CRON=15 3 * * *

# restic forget policy, applied (with --prune) after each successful backup.
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=6

# ─── Excludes (cost control) ─────────────────────────────────────────────────
# Comma-separated restic paths to skip. Bulk, re-acquirable media is excluded
# from the (metered) repo by default — members keep originals, music is
# re-rippable/re-downloadable, and recorded movies/shows are re-acquirable.
# Photos (Ente, under /storage/ente-minio) are NEVER excluded: they are the
# irreplaceable data the whole pitch rests on.
#
# ⚠️  Never exclude /storage wholesale — that silently drops the Ente photo
# blobs from every snapshot. The 2026-07-15 restore test caught exactly this
# misconfiguration in production (see docs/BACKUPS.md → Restore test log).
BACKUP_EXCLUDES=/data/jellyfin/cache,/storage/music,/storage/music-staging,/storage/movies,/storage/shows,/storage/lost+found

# ─── Optional dead-man's-switch ──────────────────────────────────────────────
# If set, the container pings this URL after a successful backup so a
# silently-failing nightly run gets noticed. CoralStack ships Uptime Kuma
# (services/uptime-kuma) — create a "Push" monitor there and paste its URL here:
#   Uptime Kuma → Add New Monitor → Monitor Type: Push → copy the Push URL
#   (http://uptime-kuma:3001/api/push/<token>) → set the heartbeat interval to
#   ~26h so a skipped nightly backup trips the alert. Then set it below and
#   `docker compose up -d backup`. The container reaches Kuma by name on the
#   coralstack network — no public exposure needed for the ping.
HEALTHCHECK_URL=
