# ─── Dispatcharr VPN egress (Gluetun → ExpressVPN) ───────────────────────────
# Dispatcharr's outbound IPTV traffic egresses through this tunnel so the apps
# VM's residential IP isn't exposed to the provider. See the compose file header
# for the full rationale. Injected into the Gluetun container via env_file.
#
# These are NOT your normal ExpressVPN login. Get them from:
#   expressvpn.com → Advanced Setup → Manual Configuration
# That page shows a dedicated OpenVPN username + password — paste them here.
OPENVPN_USER=
OPENVPN_PASSWORD=

# Egress location (Gluetun var). Must be a country your IPTV provider permits.
# Comma-separated list; Gluetun picks among matching servers.
SERVER_COUNTRIES=Canada
