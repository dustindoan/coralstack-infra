# Ente janitor configuration. Copy to .env (hand-created on the box, like
# every service .env). The Ente DB password is NOT set here — the compose
# reads it from ../ente/.env.

# When the scoped run fires. Keep it AFTER the nightly backup (03:15) with
# enough slack for the backup to finish: purging only after the snapshot ran
# is what guarantees every deleted blob reached the backup at least once.
# See docs/ENTE_STORAGE.md before changing either schedule.
JANITOR_CRON=30 5 * * *

# The effective purge window in days (replaces Ente's hard-coded 45).
# Objects emptied from trash are purged from disk once they're this old.
# Minimum 1 — below that, blobs could vanish before the nightly backup ever
# captured them, leaving no recovery path at all. 2 gives every blob two
# snapshot opportunities.
JANITOR_MIN_AGE_DAYS=2

# Optional dead-man's-switch + gauge: an Uptime Kuma push-monitor URL (or
# healthchecks.io). The janitor appends msg=pending=<n> bytes=<n> so the
# purge-pending backlog shows up in monitoring history.
JANITOR_HEALTHCHECK_URL=
