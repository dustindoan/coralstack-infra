# Ente Photos config. Generated secrets are populated by setup.sh from your
# root .env on first run.
#
# Migrating from an existing Ente install: cp /path/to/old/ente/.env services/ente/.env
# setup.sh leaves existing values alone.

# Image tags. Pinning to `latest` during trial — bump to a date-tagged image
# (see ghcr.io/ente-io/server, ghcr.io/ente-io/web) once production-ready.
ENTE_SERVER_VERSION=latest
ENTE_WEB_VERSION=latest

# Postgres password (generated by setup.sh).
ENTE_DB_PASSWORD=

# MinIO root credentials. Ente prod has separate keys per cloud (B2/Wasabi/SCW)
# but on self-host all three "buckets" point at the same MinIO, so we use one
# pair of creds for all of them in museum.yaml.
ENTE_MINIO_USER=
ENTE_MINIO_PASSWORD=

# Museum cryptographic material — sized to match libsodium APIs museum calls
# into (crypto_secretbox_KEYBYTES=32, crypto_generichash_BYTES_MAX=64). DO NOT
# regenerate after data exists: changing ENTE_MUSEUM_KEY bricks every stored
# encryption key, and changing ENTE_MUSEUM_HASH invalidates every user record.
ENTE_MUSEUM_KEY=
ENTE_MUSEUM_HASH=
ENTE_JWT_SECRET=
