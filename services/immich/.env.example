# Immich config. Variable names match upstream's conventions exactly so we
# can include their compose file verbatim (see services/immich/docker-compose.yml).
#
# setup.sh populates UPLOAD_LOCATION and DB_DATA_LOCATION from your root .env
# and generates DB_PASSWORD on first run. IMMICH_VERSION is set by setup.sh
# to match the upstream compose it fetched.
#
# Migrating from an existing Immich install:
#   cp /path/to/existing/immich/.env services/immich/.env
# setup.sh will leave the existing file alone. Your data stays where it is
# (the compose just reads the same UPLOAD_LOCATION and DB_DATA_LOCATION).

IMMICH_VERSION=

UPLOAD_LOCATION=
DB_DATA_LOCATION=

DB_USERNAME=immich
DB_DATABASE_NAME=immich
DB_PASSWORD=
