# Immich config. setup.sh fills in the password fields — everything else is
# already set to sensible defaults. All values here are read directly by the
# immich-server and immich-postgres containers via `env_file:`.

# ─── Immich server → Postgres/Redis ──────────────────────────────────────────
DB_HOSTNAME=immich-postgres
DB_USERNAME=immich
DB_DATABASE_NAME=immich
DB_PASSWORD=
REDIS_HOSTNAME=immich-redis
UPLOAD_LOCATION=/usr/src/app/upload

# ─── Postgres container init (must match DB_* above) ─────────────────────────
POSTGRES_USER=immich
POSTGRES_DB=immich
POSTGRES_PASSWORD=
POSTGRES_INITDB_ARGS=--data-checksums

# ─── OIDC via Pocket ID ──────────────────────────────────────────────────────
# These are configured in Immich's admin UI (Settings → Authentication → OAuth),
# not via env. After Pocket ID is up, follow docs/ONBOARDING.md.
