# ─── Jellyfin SSO (Pocket ID OIDC) ───────────────────────────────────────────
# Register Jellyfin as an OIDC client in Pocket ID (docs/ONBOARDING.md §1), then
# paste the returned credentials here. On the next `./setup.sh` run, the SSO
# plugin config (SSO-Auth.xml) is rendered from services/jellyfin/SSO-Auth.xml.template
# with these values — no manual clicking in the plugin UI.
#
# Callback URL to register in Pocket ID:
#   https://media.<BASE_DOMAIN>/sso/OID/redirect/pocket-id
JELLYFIN_OIDC_CLIENT_ID=
JELLYFIN_OIDC_CLIENT_SECRET=
