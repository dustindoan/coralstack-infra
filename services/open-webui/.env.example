# ─── Open WebUI ───────────────────────────────────────────────────────────────
# Generated by setup.sh — do not set manually.
WEBUI_SECRET_KEY=

# ─── Pocket ID OIDC ──────────────────────────────────────────────────────────
# Register Open WebUI in Pocket ID admin UI, then paste the credentials here.
# Redirect URI to register: https://ai.<BASE_DOMAIN>/oauth/oidc/callback
# Login button appears automatically once OAUTH_CLIENT_ID is non-empty.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
