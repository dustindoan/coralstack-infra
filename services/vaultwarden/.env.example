# Vaultwarden secrets. setup.sh generates these.

# ─── Signup control ──────────────────────────────────────────────────────────
# Default closed: random internet visitors finding the URL can't create
# accounts. SSO_SIGNUPS_MATCH_EMAIL (below) is a separate code path — Pocket ID
# users still get auto-provisioned on first SSO login. To allow open signups
# for testing, flip to true; never run that way on a publicly-reachable host.
SIGNUPS_ALLOWED=false

# Admin panel token. Leave blank to disable the admin panel entirely.
# To access: https://vault.${BASE_DOMAIN}/admin — paste this token.
ADMIN_TOKEN=

# ─── OIDC via Pocket ID ──────────────────────────────────────────────────────
# See docs/ONBOARDING.md for the full SSO wiring walkthrough + recovery
# prerequisites. SSO_AUTHORITY is set in services/vaultwarden/docker-compose.yml
# (where ${BASE_DOMAIN} from root .env can be interpolated — env_file values
# get passed as literals, no substitution).
#
# Note: first-SSO-login (pure self-service) works because we run the OIDCWarden
# fork; mainline Vaultwarden has a bug (vaultwarden#6316) that bounces new SSO
# users. See the image line in docker-compose.yml for context.
SSO_ENABLED=true
SSO_ONLY=false                              # false = keep master password as fallback
SSO_SIGNUPS_MATCH_EMAIL=true                # auto-link existing accounts by email
SSO_ALLOW_UNKNOWN_EMAIL_VERIFICATION=true   # Pocket ID doesn't assert verified status; safe because Pocket ID is our own IdP
SSO_PKCE=true
# Pocket ID only emits the `groups` claim if the `groups` scope is requested
# (its docs are misleading on this — confirmed in source). Including `groups`
# unconditionally so future group-based authorization works without rework.
SSO_SCOPES=email profile groups
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
