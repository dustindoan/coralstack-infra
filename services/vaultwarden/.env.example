# Vaultwarden secrets. setup.sh generates these.

# Admin panel token. Leave blank to disable the admin panel entirely.
# To access: https://vault.${BASE_DOMAIN}/admin — paste this token.
ADMIN_TOKEN=

# ─── OIDC via Pocket ID (experimental) ───────────────────────────────────────
# Vaultwarden's native SSO is recent — verify against upstream docs before
# enabling in production. For the alpha phase, leave SSO disabled and use
# the master password (passphrase).
SSO_ENABLED=false
# SSO_AUTHORITY=https://id.${BASE_DOMAIN}
# SSO_CLIENT_ID=vaultwarden
# SSO_CLIENT_SECRET=
